# Denkeeper Configuration
# Copy this file to ~/.denkeeper/denkeeper.toml and fill in your values.
# WARNING: This file contains secrets — do NOT commit it to version control.

# ---------------------------------------------------------------------------
# Adapters — at least one must be configured
# ---------------------------------------------------------------------------

[telegram]
# Bot token from @BotFather (or set DENKEEPER_TELEGRAM_TOKEN env var)
token = "YOUR_TELEGRAM_BOT_TOKEN"
# Security: only these Telegram user IDs can interact with the bot.
# Find your ID by messaging @userinfobot on Telegram.
allowed_users = [123456789]

# [discord]
# # Discord bot token from the Discord Developer Portal.
# # Set this to enable the Discord adapter (DM and guild channel support).
# token = "YOUR_DISCORD_BOT_TOKEN"  # Or set DENKEEPER_DISCORD_TOKEN env var
# # Security: only these Discord user snowflake IDs can interact with the bot.
# # Right-click a user in Discord (developer mode enabled) to copy their ID.
# allowed_users = ["123456789012345678"]

[llm]
# Provider to use: "openrouter" (default), "anthropic", or "ollama"
default_provider = "openrouter"
# Model to use (format depends on provider)
default_model = "anthropic/claude-sonnet-4-20250514"
# Maximum estimated cost per conversation session (USD)
max_cost_per_session = 1.0

[llm.openrouter]
# API key from https://openrouter.ai/keys (or set DENKEEPER_LLM_OPENROUTER_API_KEY env var)
api_key = "YOUR_OPENROUTER_API_KEY"

# [llm.anthropic]
# # Direct Anthropic API key (sk-ant-...). Set default_provider = "anthropic" above.
# # Bypasses OpenRouter; requires no llm.openrouter.api_key when set as the provider.
# api_key = "YOUR_ANTHROPIC_API_KEY"  # Or set DENKEEPER_LLM_ANTHROPIC_API_KEY env var
# # Optional: override the API endpoint (e.g. for Bedrock/Vertex proxies).
# # base_url = "https://api.anthropic.com"

# ---------------------------------------------------------------------------
# LLM Fallback Strategies
# ---------------------------------------------------------------------------
# Each [[llm.fallback]] entry defines one fallback step, evaluated in order.
#
# trigger values:
#   "cost_limit" — pre-call; fires when the session crosses the agent's soft or
#                  hard cost limit (cost_limit_soft / cost_limit_hard). Requires
#                  scope = "soft" | "hard".
#   "rate_limit" — fires on HTTP 429. Use wait_and_retry, switch_provider, or
#                  switch_model to recover.
#   "error"      — fires on retryable server errors (5xx, network failures).
#                  Non-retryable errors (400, 401, 402) skip all fallbacks.
#
# action values:
#   "switch_provider"  — route to a different registered provider (requires provider)
#   "switch_model"     — stay on same provider, use a different model (requires model)
#   "wait_and_retry"   — retry with backoff (requires max_retries > 0)
#
# backoff values: "exponential" (default, capped at 30s) | "constant" (1s)
#
# Legacy "low_funds" rules (with `threshold`) are auto-migrated to
# `cost_limit` + `scope = "soft"` on load.

# Switch to a free model once the soft cost limit is crossed.
# [[llm.fallback]]
# trigger = "cost_limit"
# action  = "switch_model"
# scope   = "soft"
# model   = "meta-llama/llama-3.1-8b-instruct:free"

# Retry up to 3 times with exponential backoff on rate limiting.
# [[llm.fallback]]
# trigger     = "rate_limit"
# action      = "wait_and_retry"
# max_retries = 3
# backoff     = "exponential"

# Fall back to a free model on server errors.
# [[llm.fallback]]
# trigger = "error"
# action  = "switch_model"
# model   = "meta-llama/llama-3.1-8b-instruct:free"

[session]
# Permission tier controls what the agent can do.
# "supervised"  — chat, memory, tools (default; future actions require approval)
# "autonomous"  — all capabilities (intended for sandboxed sessions)
# "restricted"  — chat, read-only tools, memory only
# tier = "supervised"

# ---------------------------------------------------------------------------
# Agent Instances (Multi-Agent)
# ---------------------------------------------------------------------------
# Define multiple agents, each with their own persona, LLM model, and adapter
# bindings. If no [[agents]] section is present, a single "default" agent is
# synthesized from the [agent] and [session] settings above.
#
# One agent MUST be named "default" — it handles messages that don't match
# any specific binding.
#
# Adapter binding formats:
#   "telegram"        — wildcard: all Telegram messages go to this agent
#   "telegram:12345"  — specific: only messages from chat ID 12345

# [[agents]]
# name         = "default"
# description  = "General-purpose personal assistant"
# persona_dir  = "~/.denkeeper/agents/default"
# adapters     = ["telegram"]
# # llm_model  = "anthropic/claude-sonnet-4-20250514"   # optional override
# # session_tier = "supervised"                          # optional override

# [[agents]]
# name         = "work-assistant"
# description  = "Focused work productivity agent"
# persona_dir  = "~/.denkeeper/agents/work-assistant"
# adapters     = ["telegram:987654321"]   # bound to a specific chat
# llm_model    = "openai/gpt-4o"
# session_tier = "restricted"

[memory]
# Path to SQLite database for conversation history
# db_path = "~/.denkeeper/data/memory.db"  # default

[log]
# Log level: debug, info, warn, error
level = "info"
# Log format: text, json
format = "text"

# ---------------------------------------------------------------------------
# Voice (STT / TTS)
# ---------------------------------------------------------------------------
# Enables speech-to-text (incoming voice messages → text) and optionally
# text-to-speech (replies sent back as voice). Requires an OpenAI API key.

# [voice]
# stt_provider = "openai"           # transcribe incoming voice messages
# tts_provider = "openai"           # synthesize replies to voice (requires auto_voice_reply)
# tts_voice = "alloy"               # OpenAI voice: alloy, echo, fable, onyx, nova, shimmer
# auto_voice_reply = false           # reply with voice when user sends a voice message
#
# [voice.openai]
# api_key = "YOUR_OPENAI_API_KEY"

# ---------------------------------------------------------------------------
# External REST API
# ---------------------------------------------------------------------------
# Exposes an HTTP API for external integrations: mobile clients, dashboards,
# automation. Disabled by default.

# [api]
# enabled = true
# listen = ":8080"                 # address to bind (default ":8080")
# tls = true                       # enable HTTPS (requires cert_file + key_file)
# cert_file = "certs/api.crt"
# key_file = "certs/api.key"
# cors_origins = ["https://dashboard.example.com"]  # allowed CORS origins
# rate_limit = 10.0                # max requests per second per API key (0 = unlimited)

# API keys — each key has a name, secret, and list of scopes.
# Valid scopes: chat, sessions:read, costs:read, skills:read, skills:write,
#               schedules:read, schedules:write, approvals:read, approvals:write,
#               health, admin

# Web dashboard key — needs all read scopes + approvals:write to manage approvals.
# Navigate to http://localhost:8080 and enter this key to log in.
# [[api.keys]]
# name   = "dashboard"
# key    = "dk-your-dashboard-key-here"
# scopes = ["admin", "sessions:read", "costs:read", "skills:read", "schedules:read", "approvals:read", "approvals:write"]

# [[api.keys]]
# name   = "mobile-app"
# key    = "dk-your-secret-key-here"
# scopes = ["chat", "sessions:read", "costs:read"]

# [[api.keys]]
# name   = "monitoring"
# key    = "dk-monitoring-key-here"
# scopes = ["health", "costs:read"]

# --- OpenTelemetry Observability ---
# [otel]
# enabled = false
# traces_endpoint = ""          # OTLP HTTP endpoint, e.g. "http://localhost:4318"
# service_name = "denkeeper"

# --- Dashboard Authentication ---
# Password login: generate a hash with `denkeeper passwd`
# [api.auth]
# password_hash = ""            # bcrypt hash from `denkeeper passwd`
# session_secret = ""           # hex-encoded AES-256 key (64 hex chars); generate with: openssl rand -hex 32
# session_max_age = "24h"
#
# OAuth2/OIDC SSO (optional)
# [api.auth.oidc]
# enabled = false
# issuer = ""                   # e.g. "https://accounts.google.com"
# client_id = ""
# client_secret = ""
# redirect_url = ""             # e.g. "https://denkeeper.example.com/auth/callback"
# scopes = ["openid", "email", "profile"]
# allowed_emails = []           # required non-empty when enabled

# ---------------------------------------------------------------------------
# Web Capabilities — Search & Fetch (ENABLED BY DEFAULT)
# ---------------------------------------------------------------------------
# Adds web_search and web_fetch MCP tools to every agent. Lightweight and
# stateless — no Docker required. Uses free DuckDuckGo search out of the box.
#
# Web tools are enabled by default. Set enabled = false to disable.

# [web]
# enabled = true                   # default: true (set to false to disable)

# [web.search]
# provider = "duckduckgo"          # "duckduckgo" (default, no key) or "tavily"
# api_key  = ""                    # Required for tavily (or DENKEEPER_SEARCH_API_KEY env var)
# max_results = 5                  # Default 5, max 10

# [web.fetch]
# timeout          = "30s"
# max_size_bytes   = 5242880       # 5MB
# user_agent       = "Denkeeper/1.0 (+https://denkeeper.io)"
# respect_robots_txt = false       # Check robots.txt before fetching
# respect_agents_txt = false       # Check agents.txt before fetching

# [web.fetch.jina]
# enabled = false                  # Enable Jina Reader fallback for JS-heavy pages

# ---------------------------------------------------------------------------
# Deterministic Compute — run_javascript (ENABLED BY DEFAULT)
# ---------------------------------------------------------------------------
# Adds the run_javascript MCP tool to every agent. Runs a short JavaScript
# snippet (sandboxed goja runtime — no network, filesystem, or subprocess)
# against JSON input to transform, format, classify, count, or bucket data
# deterministically, instead of computing it in completion tokens. Useful for
# skills that build formatted digests. Disabled in the "restricted" tier.

# [script]
# enabled          = true          # default: true (set to false to disable)
# timeout          = "2s"          # per-call wall-clock limit
# max_output_chars = 16000         # cap on returned result length
# max_input_bytes  = 262144        # cap on accepted input payload (256 KiB)
# max_concurrent   = 4             # process-global cap on simultaneous VM executions (0 = default 4; negative = unbounded)
# max_concurrent_per_agent = 0     # per-agent cap so one agent can't monopolize the pool (0 = off; negative = unbounded)

# ---------------------------------------------------------------------------
# Browser Automation (Docker)
# ---------------------------------------------------------------------------
# Full Playwright-based browser control in a hardened Docker container.
# Requires Docker on the host. Registers Playwright MCP tools automatically.

# [browser]
# enabled      = false
# image        = "ghcr.io/temikus/denkeeper-browser:latest"
# memory_limit = "512m"
# cpu_limit    = "1"

# ---------------------------------------------------------------------------
# Schedules
# ---------------------------------------------------------------------------
# Each [[schedules]] entry defines a recurring task.
#
# Required fields:
#   name        - unique identifier
#   type        - "system" (core tasks, higher priority) or "agent" (skill runs)
#   schedule    - when to run (see formats below)
#
# Schedule expression formats:
#   Named:    @hourly  @daily  @midnight  @weekly  @monthly  @yearly  @annually
#   Interval: @every <duration>   e.g. @every 5m, @every 1h30m, @every 24h
#   Cron:     <min> <hour> <dom> <month> <dow>
#             e.g. "0 8 * * 1-5" = weekdays at 08:00 UTC
#             Fields support: * (all), n, n-m (range), */n (step), a,b,c (list)
#             Day-of-week: 0 and 7 both mean Sunday.
#
# Optional fields:
#   skill        - skill to invoke on each run
#   agent        - target agent name (default: "default")
#   session_tier - "supervised" (default), "autonomous", or "restricted"
#   channel      - delivery channel e.g. "telegram:123456789"
#   tags         - freeform labels for filtering and organisation
#   enabled      - true (default) or false to pause without removing

# --- System schedule example ---
# System schedules are for core housekeeping. They run with higher priority
# than agent schedules and should not be modifiable by the agent itself.
#
# [[schedules]]
# name         = "agent-heartbeat"
# type         = "system"
# schedule     = "@every 5m"
# tags         = ["system", "health"]
# enabled      = true

# --- Agent schedule examples ---

# Daily briefing at 08:00 UTC every day.
# [[schedules]]
# name         = "daily-briefing"
# type         = "agent"
# schedule     = "@daily"
# skill        = "daily-briefing"
# session_tier = "supervised"
# channel      = "telegram:123456789"
# tags         = ["morning", "briefing"]
# enabled      = true

# Weekly expense check every Friday at 18:00 UTC.
# [[schedules]]
# name         = "weekly-expense-check"
# type         = "agent"
# schedule     = "0 18 * * 5"
# skill        = "expense-tracker"
# session_tier = "restricted"
# tags         = ["finance", "weekly"]
# enabled      = true

# Weekday standup reminder at 09:00 UTC, Monday–Friday.
# [[schedules]]
# name         = "standup-reminder"
# type         = "agent"
# schedule     = "0 9 * * 1-5"
# skill        = "standup"
# session_tier = "supervised"
# channel      = "telegram:123456789"
# tags         = ["work", "morning"]
# enabled      = true

# ---------------------------------------------------------------------------
# Plugins
# ---------------------------------------------------------------------------
# Plugins declare capabilities explicitly and participate in permission checks
# and lifecycle management. Two execution strategies:
#
#   "subprocess" — trusted, runs as a child process with direct MCP stdio
#   "docker"     — sandboxed, runs in a Docker/Podman container with isolation
#
# Subprocess required fields:
#   type, command, capabilities
#
# Docker required fields:
#   type, image, capabilities
#
# Docker optional fields:
#   command      - entrypoint override (default: image ENTRYPOINT)
#   args         - arguments passed to the entrypoint
#   memory_limit - container memory limit (e.g. "256m", "1g")
#   cpu_limit    - container CPU limit (e.g. "0.5", "2")
#   network      - Docker network mode (default: "none" — fully isolated)
#   volumes      - bind mounts in Docker format ("host:container[:ro]")
#
# Common optional fields:
#   args         - command-line arguments
#   env          - environment variable overrides (values support $VAR expansion)
#
# Plugin names must not conflict with [tools.*] entry names.

# --- Subprocess plugin (trusted) ---
# [plugins.web-scraper]
# type         = "subprocess"
# command      = "denkeeper-plugin-scraper"
# args         = ["--headless"]
# env          = { CHROMIUM_PATH = "/usr/bin/chromium" }
# capabilities = ["tools"]

# --- Docker plugin (sandboxed) ---
# Requires Docker or Podman on the host.
# The container runs with --cap-drop ALL, --read-only, --network none by default.
# [plugins.code-runner]
# type         = "docker"
# image        = "ghcr.io/example/mcp-code-runner:latest"
# memory_limit = "256m"
# cpu_limit    = "0.5"
# network      = "none"
# volumes      = ["/tmp/denkeeper-data:/data:ro"]
# env          = { API_KEY = "$CODE_RUNNER_KEY" }
# capabilities = ["tools"]

# ---------------------------------------------------------------------------
# Security — Plugin Signature Verification
# ---------------------------------------------------------------------------
# When trusted_keys is configured, denkeeper verifies Ed25519 signatures of
# subprocess plugin binaries on startup. Each plugin binary must have a
# matching .sig file alongside it.
#
# Generate a signing key pair:
#   denkeeper plugin keygen --out ~/.denkeeper/keys/publisher
#   # Creates publisher.pub (distribute) and publisher.key (keep secret)
#
# Sign a plugin:
#   denkeeper plugin sign --key ~/.denkeeper/keys/publisher.key /usr/bin/my-plugin
#   # Creates /usr/bin/my-plugin.sig
#
# allow_unsigned = true  (default) — unsigned plugins produce a warning
# allow_unsigned = false — unsigned plugins are rejected at startup

# [security]
# trusted_keys  = ["~/.denkeeper/keys/publisher.pub"]
# allow_unsigned = true

# ---------------------------------------------------------------------------
# Sandbox Runtime — Backend for Docker-type plugins
# ---------------------------------------------------------------------------
# Selects how Docker-type plugins are executed. Default is "docker" which uses
# the local Docker/Podman daemon. "kubernetes" creates ephemeral Pods with
# hardened security contexts.

# [sandbox]
# runtime = "docker"    # "docker" (default) or "kubernetes"

# [sandbox.kubernetes]
# namespace     = "denkeeper-sandboxes"   # K8s namespace for sandbox Pods
# kubeconfig    = ""                       # Path to kubeconfig (empty = in-cluster)
# runtime_class = ""                       # RuntimeClassName (e.g., "gvisor", "kata")
