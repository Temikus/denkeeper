    "definitions": {
        "github_com_Temikus_denkeeper_internal_config.FallbackConfig": {
            "type": "object",
            "properties": {
                "action": {
                    "description": "\"switch_provider\" | \"switch_model\" | \"wait_and_retry\"",
                    "type": "string"
                },
                "backoff": {
                    "description": "\"exponential\" (default) | \"constant\"",
                    "type": "string"
                },
                "max_retries": {
                    "description": "required for wait_and_retry",
                    "type": "integer"
                },
                "model": {
                    "description": "required for switch_model; optional for switch_provider",
                    "type": "string"
                },
                "provider": {
                    "description": "required for switch_provider",
                    "type": "string"
                },
                "threshold": {
                    "description": "required for low_funds (USD remaining)",
                    "type": "number"
                },
                "trigger": {
                    "description": "\"error\" | \"rate_limit\" | \"low_funds\"",
                    "type": "string"
                }
            }
        },
        "github_com_Temikus_denkeeper_internal_config.OpenRouterReasoningCfg": {
            "type": "object",
            "properties": {
                "effort": {
                    "description": "Effort sets the reasoning effort level: \"xhigh\", \"high\", \"medium\",\n\"low\", \"minimal\", \"none\". Mutually exclusive with MaxTokens.",
                    "type": "string"
                },
                "enabled": {
                    "description": "Enabled activates reasoning with model defaults. Inferred true when\nEffort or MaxTokens is set.",
                    "type": "boolean"
                },
                "exclude": {
                    "description": "Exclude omits reasoning from the response (tokens are still billed).",
                    "type": "boolean"
                },
                "max_tokens": {
                    "description": "MaxTokens sets the reasoning token budget. Mutually exclusive with Effort.",
                    "type": "integer"
                }
            }
        },
